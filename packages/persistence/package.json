{
  "name": "@runroot/persistence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Persistence contracts and storage adapters for Runroot.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@runroot/approvals": "workspace:*",
    "@runroot/config": "workspace:*",
    "@runroot/dispatch": "workspace:*",
    "@runroot/domain": "workspace:*",
    "@runroot/events": "workspace:*",
    "@runroot/tools": "workspace:*",
    "pg": "^8.20.0",
    "sql.js": "^1.14.1"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/sql.js": "^1.4.11",
    "pg-mem": "^3.0.14"
  }
}
