{
  "name": "@runroot/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared operator service and programmatic SDK helpers for Runroot.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@runroot/approvals": "workspace:*",
    "@runroot/config": "workspace:*",
    "@runroot/core-runtime": "workspace:*",
    "@runroot/dispatch": "workspace:*",
    "@runroot/domain": "workspace:*",
    "@runroot/persistence": "workspace:*",
    "@runroot/replay": "workspace:*",
    "@runroot/templates": "workspace:*",
    "@runroot/tools": "workspace:*"
  },
  "devDependencies": {
    "pg-mem": "^3.0.14"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
